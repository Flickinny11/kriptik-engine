ANTHROPIC_API_KEY=           # Required for Claude models
OPENAI_API_KEY=              # Optional — enables GPT/o-series models
GOOGLE_API_KEY=              # Optional — enables Gemini models (stub)
XAI_API_KEY=                 # Optional — enables Grok models
BRAVE_SEARCH_API_KEY=        # Required — web search
FIRECRAWL_API_KEY=           # Optional — enhanced competitor analysis
QDRANT_URL=                  # Required — semantic search
QDRANT_API_KEY=              # Optional — Qdrant Cloud auth
HF_API_KEY=                  # Optional — HuggingFace embeddings

# Modal Prism Pipeline
MODAL_PRISM_ENABLED=true
MODAL_PRISM_SPAWN_URL=       # Modal function URL for prism pipeline
MODAL_PRISM_PLAN_URL=        # Modal function URL for planning-only endpoint
MODAL_PRISM_EDIT_URL=        # Modal function URL for single-node edit

# Modal Prism Preview Server
MODAL_PRISM_PREVIEW_URL=     # Modal tunnel URL for preview (e.g. https://kriptik-prism--serve-preview.modal.run)

# Vercel Deployment (Prism static bundle deploy)
VERCEL_TOKEN=                # Vercel API token for deployments
VERCEL_TEAM_ID=              # Optional: Vercel team ID for team deployments

# Cloudflare R2 (Prism image/asset storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kriptik-prism-assets
R2_PUBLIC_URL=               # e.g. https://assets.kriptik.app
