{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Vercel__search_vercel_documentation",
      "mcp__claude_ai_Vercel__get_deployment_build_logs",
      "mcp__claude_ai_Vercel__get_runtime_logs",
      "mcp__claude_ai_Vercel__web_fetch_vercel_url",
      "mcp__architecture-map__search_architecture",
      "mcp__architecture-map__get_interface",
      "mcp__architecture-map__check_integration",
      "mcp__architecture-map__query_endpoints",
      "mcp__architecture-map__query_dependencies",
      "mcp__architecture-map__update_map",
      "Bash(cat .forge/*)",
      "Bash(cat .forge/**/*)",
      "Bash(.forge/hooks/*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "mcpServers": {
    "architecture-map": {
      "command": "bash",
      "args": [".forge/mcp/start-mcp.sh"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .forge/hooks/post-edit.sh \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .forge/hooks/post-task.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .forge/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  }
}
